# Sauce CRM OAuth relay — per-provider OAuth client credentials.
# Copy to .env (gitignored). Fill in only the providers you want to use.

# --- Google Workspace ---
# Create at https://console.cloud.google.com/apis/credentials → "Web application"
# Add http://<your-relay-host>:8787/callback/google to authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/callback/google

# --- Microsoft 365 ---
# Create at https://entra.microsoft.com → App registrations → Web platform
# Add http://<your-relay-host>:8787/callback/microsoft as a redirect URI.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://127.0.0.1:8787/callback/microsoft
MICROSOFT_TENANT=common

# --- Notion (OAuth, not internal integration) ---
# Create at https://www.notion.so/profile/integrations → Public integration
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://127.0.0.1:8787/callback/notion

# --- Relay self-config ---
# Optional. If unset, relay generates a token on first start and writes
# /data/relay-token.txt for the plugin to consume.
RELAY_BEARER_TOKEN=

# Session TTL (seconds). After this, a session_id can no longer be used to
# poll for tokens. Default 900 (15 min).
RELAY_SESSION_TTL=900
