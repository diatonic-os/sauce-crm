{
  "name": "sauce-crm",
  "version": "0.5.0",
  "description": "LSP-typed CRM + knowledge base for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit && node esbuild.config.mjs production",
    "install:vault": "node scripts/install-to-vault.mjs",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc -noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sdk:gen": "esbuild sdk/generator/generate.ts --bundle --platform=node --format=esm | node --input-type=module",
    "sdk:check": "npm run sdk:gen && git diff --exit-code -- sdk/generated",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "daemon:build": "tsc -noEmit -p daemon/tsconfig.json && node daemon/esbuild.config.mjs production",
    "daemon:dev": "node daemon/esbuild.config.mjs",
    "daemon:test": "vitest run daemon"
  },
  "keywords": [
    "obsidian",
    "crm",
    "knowledge-base",
    "graph",
    "lsp"
  ],
  "author": "Drew Fortini",
  "license": "MIT",
  "devDependencies": {
    "@lancedb/lancedb": "0.30.0",
    "@types/d3-force": "3.0.10",
    "@types/geojson": "7946.0.16",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/ui": "4.1.9",
    "builtin-modules": "^5.3.0",
    "esbuild": "^0.28.1",
    "esbuild-svelte": "0.9.5",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jsdom": "29.1.1",
    "obsidian": "latest",
    "prettier": "^3.9.3",
    "svelte": "5.56.4",
    "svelte-preprocess": "6.0.5",
    "tslib": "^2.6.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "d3-force": "3.0.0",
    "maplibre-gl": "5.24.0",
    "pmtiles": "4.4.1"
  }
}
