{
  "name": "sauce-graph",
  "version": "0.1.0",
  "description": "LSP-typed CRM + knowledge base for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "crm", "knowledge-base", "graph", "lsp"],
  "author": "Drew Fortini",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/ui": "^4.1.7",
    "builtin-modules": "^5.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "jsdom": "^29.1.1",
    "obsidian": "latest",
    "prettier": "^3.2.5",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
