{
  "name": "sauce-crm",
  "version": "0.4.1",
  "description": "LSP-typed CRM + knowledge base for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "sdk:gen": "esbuild sdk/generator/generate.ts --bundle --platform=node --format=esm | node --input-type=module",
    "sdk:check": "npm run sdk:gen && git diff --exit-code -- sdk/generated",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "daemon:build": "tsc -noEmit -skipLibCheck -p daemon/tsconfig.json && node daemon/esbuild.config.mjs production",
    "daemon:dev": "node daemon/esbuild.config.mjs",
    "daemon:test": "vitest run daemon"
  },
  "keywords": [
    "obsidian",
    "crm",
    "knowledge-base",
    "graph",
    "lsp"
  ],
  "author": "Drew Fortini",
  "license": "MIT",
  "devDependencies": {
    "@lancedb/lancedb": "0.29.0",
    "@types/node": "^20.11.20",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitest/ui": "4.1.7",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.1",
    "esbuild-svelte": "0.9.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jsdom": "29.1.1",
    "obsidian": "latest",
    "prettier": "^3.2.5",
    "svelte": "5.55.9",
    "svelte-preprocess": "6.0.4",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "vitest": "4.1.7"
  }
}
